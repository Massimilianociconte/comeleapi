# ============================================================
# comeleapi — Variabili d'ambiente
# Copia questo file in .env e compila i valori
# ============================================================

# Server
PORT=4173
NODE_ENV=production
SESSION_SECRET=

# Admin iniziale
# Obbligatori in produzione. ADMIN_PASSWORD deve avere almeno 14 caratteri.
# Il bootstrap mantiene un solo utente con ruolo admin e disabilita gli alias.
ADMIN_USER=
ADMIN_PASSWORD=

# Supabase
SUPABASE_URL=https://PROGETTO.supabase.co
SUPABASE_SERVICE_KEY=eyJ...(service_role key dalla dashboard Supabase)

# VAPID (notifiche push)
# Genera le chiavi con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contatto pubblico confermato; non sostituire con alias non ancora attivati.
VAPID_SUBJECT=mailto:sara.bordenga@gmail.com

# CORS — origini consentite per le API pubbliche (sito su Netlify)
PUBLIC_SITE_ORIGINS=https://www.comeleapi.it,https://comeleapi.it
